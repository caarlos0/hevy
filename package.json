{
  "name": "@caarlos0/hevy",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.1",
  "description": "CLI for managing Hevy routines via the public Hevy API",
  "type": "module",
  "bin": {
    "hevy": "lib/index.cjs"
  },
  "files": [
    "dist",
    "examples",
    "README.md"
  ],
  "engines": {
    "node": ">=25.5 <26"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepublishOnly": "npm run lint && npm test && npm run build",
    "release": "./scripts/bump.sh"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.3.0",
    "prettier": "^3.3.0",
    "tsup": "^8.2.0",
    "tsx": "^4.16.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "license": "MIT",
  "author": "Carlos Alexandro Becker"
}
