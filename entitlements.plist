<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- The binary is a Node.js single executable; V8's JIT needs executable
       memory, which the Hardened Runtime (required for notarization) blocks
       unless these entitlements are granted. Without allow-jit, startup fails
       with "Failed to reserve virtual memory for CodeRange". -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
</dict>
</plist>
